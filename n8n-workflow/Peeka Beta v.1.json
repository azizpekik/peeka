      "parameters": {
        "jsCode": "// 1. Ambil output teks dari AI dan ubah jadi JSON asli\nconst rawOutput = $json.output;\nconst data = JSON.parse(rawOutput);\n\n// 2. Generate Nomor Nota (TL-PEEKA-YYYYMMDD-XXX)\nconst sekarang = new Date();\nconst tgl = sekarang.toISOString().slice(0, 10).replace(/-/g, '');\nconst randomSuffix = Math.floor(Math.random() * 1000).toString().padStart(3, '0');\nconst nomor_nota = `TL-PEEKA-${tgl}-${randomSuffix}`;\n\n// 3. Hitung Total Nominal (untuk tabel transaksi master)\nlet total_nominal = 0;\ndata.items.forEach(item => {\n  total_nominal += (item.harga * item.qty);\n});\n\nconst ringkasan = data.items.map(i => i.nama_item).join(\", \");\n\n// 4. Kirim data yang sudah matang\nreturn {\n  nomor_nota,\n  total_nominal,\n  nama_pelanggan: data.nama_pelanggan,\n  status_bayar: data.status_bayar,\n  catatan: ringkasan,\n  items: data.items // Ini nanti di-split di node selanjutnya\n};"
      },
