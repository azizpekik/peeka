      "name": "Sticky Note"
    },
    {
      "parameters": {
        "jsCode": "const text = items[0].json.raw_text || \"\";\nconst length = text.trim().length;\n\nlet status = \"PROCEED\";\nlet message = \"\";\n\nconst tooShortMessages = [\n  \"Eh, kependekan Kak! 😅 Peeka bingung mau catat apa. Contoh: 'Bakso 15rb' ya!\",\n  \"Satu kata belum cukup buat jagain cuan Kakak 💸. Yuk, tulis nominalnya juga!\",\n  \"Peeka sudah siap nih 🖊️, tapi butuh detailnya. Misal: 'Listrik 100k'. Ditunggu ya!\",\n  \"Kurang lengkap nih, Kak! ✨ Contoh: 'Jual kopi 20k'. Biar pembukuan makin rapi!\",\n  \"Duh, cuma segitu? 🤭 Peeka mau dong dikasih angka. Yuk, lengkapi transaksinya!\"\n];\n\nconst tooLongMessages = [\n  \"Aduh, kepanjangan! 😵‍💫 Peeka pusing bacanya. Ringkas intinya aja yuk, Kak!\",\n  \"Ini laporan apa novel, Kak? 😄 Ringkas dikit biar Peeka cepet catat cuannya!\",\n  \"Catatannya detail banget! Tapi Peeka butuh intinya aja, misal: 'Belanja 50k' 📝\",\n  \"Peeka mau bantu, tapi jangan panjang-panjang ya! 🍯 Poinnya aja biar sat-set!\",\n  \"Lampu Peeka kedap-kedip baca sepanjang ini ✨. Ringkas ya Kak, biar masuk laporan!\"\n];\n\nif (length < 5) {\n  status = \"TOO_SHORT\";\n  message = tooShortMessages[Math.floor(Math.random() * tooShortMessages.length)];\n} else if (length > 500) {\n  status = \"TOO_LONG\";\n  message = tooLongMessages[Math.floor(Math.random() * tooLongMessages.length)];\n}\n\nreturn [{\n  json: {\n    status,\n    message,\n    raw_text: text\n  }\n}];"
      },
